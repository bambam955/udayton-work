# Required by the OpenRouter API; rotate this value in Azure/hosting secrets for production.
OPENROUTER_API_KEY=<server-only-openrouter-key>

# Model identifier used for all chat completions in this service.
# Example values: openrouter/free, meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_MODEL=openrouter/free

# Override the default OpenRouter endpoint (including self-hosted/proxy setups).
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions

# Session lifetime (ms). After this time of inactivity, a conversation session expires.
CHAT_SESSION_TTL_MS=1800000

# Maximum number of turns kept per session; older turns are trimmed for memory/performance.
CHAT_SESSION_MAX_MESSAGES=24

# Background prune frequency (ms) for expired conversation sessions.
CHAT_CLEANUP_INTERVAL_MS=300000

# Timeout for OpenRouter requests (ms). Controls how long the microservice waits before aborting.
CHAT_REQUEST_TIMEOUT_MS=20000
