# OpenRouter API key used for AI chat requests from the browser.
# Note: in frontend apps this is visible to users and should only be used for class/demo purposes.
VITE_OPENROUTER_API_KEY=

# OpenRouter model ID to use for chat completions.
# You can swap this if a free model changes availability.
VITE_OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
