# Placeholder for an OpenRouter API key,
OPENROUTER_API_KEY=API_KEY_HERE
# The OpenRouter model to use. "openrouter/free" ensures that a free model compatible with a free API key is used.
OPENROUTER_MODEL=openrouter/free
# The length of time to wait for a response from OpenRouter.
# Initially, this defaulted to 15 seconds, but it was increased to 60 seconds because that was too short for some responses.
OPENROUTER_TIMEOUT_MS=60000
